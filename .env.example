# Robinhood Chain RPC configuration.
# Copy this file to .env and fill in values. Never commit .env.
#
# EXPO_PUBLIC_* vars are inlined into the app bundle at build time, so only put
# values here that are safe to ship in a client (a public or throttled RPC URL).
# Do NOT put private keys or secret-bearing URLs you don't want shipped.

# Network to target: "mainnet" (default) or "testnet".
EXPO_PUBLIC_RH_NETWORK=mainnet

# Optional RPC override. Leave unset to use the public rate-limited endpoint.
# For higher limits use your Alchemy URL, e.g.:
#   https://robinhood-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
EXPO_PUBLIC_RH_RPC_URL=
